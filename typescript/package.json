{
    "name": "vscode-python-tool-lsp",
    "version": "0.1.0",
    "description": "Shared TypeScript package for building VS Code Python tool extensions",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist/**/*"
    ],
    "scripts": {
        "build": "tsc",
        "watch": "tsc --watch",
        "lint": "eslint src --ext ts",
        "test": "mocha --require ts-node/register test/**/*.test.ts",
        "clean": "rimraf dist"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/microsoft/vscode-python-tool-lsp"
    },
    "author": "Microsoft Corporation",
    "license": "MIT",
    "dependencies": {
        "@vscode/python-environments": "https://pkgs.dev.azure.com/azure-public/vside/_packaging/msft_consumption/npm/registry/@vscode/python-environments/-/python-environments-1.0.0.tgz",
        "@vscode/python-extension": "^1.0.5",
        "dotenv": "^17.4.0",
        "fs-extra": "^11.3.4",
        "semver": "^7.7.4",
        "vscode-languageclient": ">=9.0.0"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/semver": "^7.7.1",
        "@types/vscode": "^1.74.0",
        "mocha": "^11.7.5",
        "rimraf": "^5.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "vscode-languageclient": ">=9.0.0"
    },
    "peerDependenciesMeta": {
        "vscode-languageclient": {
            "optional": true
        }
    }
}
